{
  "name": "batumibiz/opencart-lts",
  "description": "OpenCart 4 LTS",
  "type": "project",
  "keywords": [
    "opencart",
    "ecommerce",
    "framework",
    "opensource"
  ],
  "license": "GPL-3.0-or-later",
  "config": {
    "optimize-autoloader": true,
    "vendor-dir": "upload/system/storage/vendor/",
    "platform": {
      "php": "8.1"
    }
  },
  "require": {
    "php": ">=8.1",
    "ext-curl": "*",
    "scssphp/scssphp": "^2.1",
    "twig/twig": "^3.27"
  },
  "autoload-dev": {
    "psr-4": {
      "Tools\\PHPStan\\": ".tools/phpstan/"
    }
  },
  "scripts": {
    "check": [
      "@cs-check",
      "@static-analysis"
    ],
    "cs-fix": "php .tools/php-cs-fixer-v3.phar fix --config=.tools/php-cs-fixer.php",
    "cs-check": "php .tools/php-cs-fixer-v3.phar fix --config=.tools/php-cs-fixer.php --dry-run --diff",
    "static-analysis": "php .tools/phpstan.phar analyze -c .tools/phpstan.neon"
  }
}
