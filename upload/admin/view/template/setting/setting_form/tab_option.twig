              <div class="form-check form-switch form-switch-lg">
                <input type="hidden" name="config_product_report_status" value="0"/> <input type="checkbox" name="config_product_report_status" value="1" id="input-product-report" class="form-check-input"{% if config_product_report_status %} checked{% endif %}/>
              </div>
              <div class="form-text">{{ help_product_report }}</div>
            </div>
          </div>
          <div class="row mb-3">
            <label for="input-product-search" class="col-sm-2 col-form-label">{{ entry_product_search }}</label>
            <div class="col-sm-10">
              <select name="config_product_search" id="input-product-search" class="form-select">
                <option value="and"{% if config_product_search == 'and' %} selected{% endif %}>AND</option>
                <option value="or"{% if config_product_search == 'or' %} selected{% endif %}>OR</option>
              </select>
              <div class="form-text">{{ help_product_search }}</div>
            </div>
          </div>
