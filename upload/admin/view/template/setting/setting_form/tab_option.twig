                <option value="and"{% if config_product_filters == 'and' %} selected{% endif %}>AND</option>
                <option value="or"{% if config_product_filters == 'or' %} selected{% endif %}>OR</option>
              </select>
              <div class="form-text">{{ help_product_filters }}</div>
            </div>
          </div>
        </div>
      </div>
