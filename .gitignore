/.idea
/.cache

# Image files
/upload/image/cache/*
!/upload/image/cache/index.html
/upload/image/catalog/*
!/upload/image/catalog/index.html
!/upload/image/catalog/cart.png
!/upload/image/catalog/opencart.ico
!/upload/image/catalog/opencart-logo.png
!/upload/image/catalog/profile-pic.png
!/upload/image/catalog/demo

# Storage files
/upload/system/storage/backup/*
!/upload/system/storage/backup/index.html
/upload/system/storage/cache/*
!/upload/system/storage/cache/index.html
/upload/system/storage/download/*
!/upload/system/storage/download/index.html
/upload/system/storage/logs/*
!/upload/system/storage/logs/index.html
/upload/system/storage/marketplace/*
!/upload/system/storage/marketplace/index.html
!/upload/system/storage/marketplace/opencart.ocmod.zip
/upload/system/storage/session/*
!/upload/system/storage/session/index.html
/upload/system/storage/upload/*
!/upload/system/storage/upload/index.html

# Extension files
/upload/extension/*
!/upload/extension/index.html
!/upload/extension/ocmod
!/upload/extension/opencart

# CSS Files
/upload/admin/view/stylesheet/*.css
/upload/catalog/view/stylesheet/*.css

# Docker files
/.docker/log/apache/*
!/.docker/log/apache/.gitkeep
/.docker/log/php/*
!/.docker/log/php/.gitkeep
/.docker/log/xdebug/*
!/.docker/log/xdebug/.gitkeep
